{
  "name": "gas-ts-boilerplate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "push": "pnpm run test && pnpm run build && clasp push",
    "deploy:dev": "bash scripts/deploy.sh dev",
    "deploy:prod": "bash scripts/deploy.sh prod",
    "open": "clasp open",
    "login": "clasp login",
    "lint": "eslint 'src/server/**/*.ts'",
    "lint:fix": "eslint 'src/server/**/*.ts' --fix",
    "format": "prettier --write \"src/**/*.{ts,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@google/clasp": "^3.2.0",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/google-apps-script": "^1.0.87",
    "@types/node": "^22.7.7",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.5.0",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
